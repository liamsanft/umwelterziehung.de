---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import { formatPaths } from "../../utilities";

const projekte = await Astro.glob("../../content/projekte/*.md");
---

<DefaultLayout title="Projekte">
  <h1 class="text-4xl font-black text-dark-green">Projekte</h1>
  <div class="not-prose">
    <ul class="flex flex-col items-center">
    {projekte.map(({frontmatter, file}) => {
      return (
      <li class="flex flex-col lg:flex-row justify-between rounded-lg px-7 py-4 shadow-lg mt-16 w-full items-center">
              <img
                src={frontmatter.bild}
                alt={frontmatter.title}
                class="w-[15rem] h-max"
              />
              <div class="flex lg:ml-20 w-full mt-10 lg:mt-0 flex-col">
                <h3 class="text-xl font-bold">{frontmatter.title}</h3>
                <p class="mt-2 flex">{frontmatter.kurzbeschreibung}</p>
                <a href={frontmatter.url ? frontmatter.url : `/projekte/${formatPaths(file)}`} class="mt-3 font-bold">
                  Mehr erfahren
                </a>
              </div>
            </li>
      )
    })}
    </ul>
  </div>
</DefaultLayout>
