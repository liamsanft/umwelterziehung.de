---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import MarginContainer from "../components/atoms/MarginContainer.astro";

const datenschutzData = await Astro.glob("../content/datenschutz/*.md");
const datenschutz = datenschutzData[0];
---

<DefaultLayout title="Datenschutzerklärung">
  <MarginContainer tailwind="mt-20 pb-24 md:mt-40">
    <div class="prose max-w-none">
      <datenschutz.Content />
    </div>
  </MarginContainer>
</DefaultLayout>
