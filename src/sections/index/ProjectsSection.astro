---
import MarginContainer from "../../components/atoms/MarginContainer.astro";

const projectsData = await Astro.glob("../../content/projekte/*.md");
projectsData.sort((a, b) => {
  return a.frontmatter.priority - b.frontmatter.priority;
});
---

<section class="py-24">
  <MarginContainer>
    <h2 class="text-center text-3xl font-black text-dark-green">
      Unsere Projekte
    </h2>
    <ul class="flex flex-col items-center">
      {
        projectsData.map(({ frontmatter }) => {
          const project = frontmatter;

          return (
            <li class="flex justify-between rounded-lg px-7 py-4 shadow-lg mt-16 w-max items-center">
              <img
                src={project.bild}
                alt={project.title}
                class="w-[15rem] h-max"
              />
              <div class="flex ml-20 w-[40rem] flex-col">
                <h3 class="text-xl font-bold">{project.title}</h3>
                <p class="mt-2">{project.kurzbeschreibung}</p>
                <a href={project.url} class="mt-3 font-bold">
                  Mehr erfahren
                </a>
              </div>
            </li>
          );
        })
      }
    </ul>
  </MarginContainer>
</section>
